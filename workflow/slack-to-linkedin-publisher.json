        "jsCode": "const html = $input.first().json.data || '';\nconst originalItem = $('Safety Gate').first().json;\n\nconst match =\n  html.match(/<meta[^>]+property=[\"']og:image[\"'][^>]+content=[\"']([^\"']+)[\"']/i) ||\n  html.match(/<meta[^>]+content=[\"']([^\"']+)[\"'][^>]+property=[\"']og:image[\"']/i);\n\nconst rawUrl = match ? match[1] : null;\nconst image_url = rawUrl && /\\.(jpe?g|png|gif)(\\?|$)/i.test(rawUrl) ? rawUrl : null;\n\nreturn { json: { ...originalItem, image_url } };"
