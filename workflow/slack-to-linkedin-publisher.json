        "jsCode": "const item = $input.first().json;\nconst formattedHashtags = (item.draft_hashtags || '')\n  .split(/\\s+/)\n  .filter(Boolean)\n  .map(t => t.startsWith('#') ? t : `#${t}`)\n  .join(' ');\n\nconst postLink = item.post_link ? `\\n\\n${item.post_link}` : '';\nconst hashtagSection = formattedHashtags ? `\\n\\n${formattedHashtags}` : '';\nconst final_text = item.post_text + postLink + hashtagSection;\n\nreturn {\n  json: {\n    ...item,\n    final_text: final_text,\n    final_hashtags: formattedHashtags,\n    image_url: item.draft_image_url || null\n  }\n};"
