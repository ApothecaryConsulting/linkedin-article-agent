# n8n runtime
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_EDITOR_BASE_URL=https://your-ngrok-domain.ngrok-free.app
N8N_ENCRYPTION_KEY=                    # generate: openssl rand -hex 16
N8N_BLOCK_ENV_ACCESS_IN_NODE=false

# Public base URL used for webhook callbacks and approval button links
# Set to your ngrok tunnel URL (or any public hostname if not using ngrok)
WEBHOOK_URL=https://your-ngrok-domain.ngrok-free.app

# ngrok — omit NGROK_AUTHTOKEN entirely to disable ngrok
NGROK_AUTHTOKEN=                       # https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_DOMAIN=your-static-subdomain.ngrok-free.app     # optional: pins to a static URL so it never changes on restart

# Per-user config — JSON mapping Slack user ID → linkedin_person_id, display name, and LinkedIn publish sub-workflow ID
# Find Slack user IDs: Slack profile → ⋮ → Copy member ID
# Find LinkedIn person ID: GET https://api.linkedin.com/v2/userinfo (sub field)
# sub_workflow_id: set after deploying the linkedin-publish-userN.json sub-workflows (see n8n UI → workflow URL → /workflow/<id>)
USER_CONFIG={"SLACK_USER_ID_1":{"linkedin_person_id":"LINKEDIN_ID_1","name":"User 1","sub_workflow_id":"N8N_WORKFLOW_ID_1"},"SLACK_USER_ID_2":{"linkedin_person_id":"LINKEDIN_ID_2","name":"User 2","sub_workflow_id":"N8N_WORKFLOW_ID_2"},"SLACK_USER_ID_3":{"linkedin_person_id":"LINKEDIN_ID_3","name":"User 3","sub_workflow_id":"N8N_WORKFLOW_ID_3"}}

# Slack channel for shared logging (approvals now go to individual DMs automatically)
LOG_CHANNEL_ID=                        # Slack channel ID (e.g. C0AG7573N0Y) — copy from channel details
